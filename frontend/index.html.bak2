<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SecureStay — Hotel Surveillance System</title>
    <!-- Modern clean fonts for the new UI -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Rajdhani:wght@500;600;700&family=Share+Tech+Mono&family=Exo+2:wght@600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body class="bg-slate-900 text-slate-100 antialiased">

<!-- ===== LOGIN ===== -->
<div id="login-overlay" class="login-overlay">
  <div class="login-card">
    <div class="login-logo">
      <div class="icon">🏨</div>
      <h1>SECURE<span style="color:var(--primary)">STAY</span></h1>
      <p>Advanced Hotel Surveillance</p>
    </div>
    <form id="login-form">
      <div class="form-group">
        <label>Admin Username</label>
        <input type="text" id="username" placeholder="admin@hotel.com" value="admin" />
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" id="password" placeholder="••••••••" value="admin" />
      </div>
      <div class="error-text" id="login-error"></div>
      <button type="submit" class="btn-login" onclick="login(event)">SECURE LOGIN</button>
    </form>
    <div class="login-meta">
      🔒 ENCRYPTED CONNECTION &nbsp;|&nbsp; v2.5.0
    </div>
  </div>
</div>

<!-- ===== DASHBOARD ===== -->
<div id="dashboard" class="hidden">

  <!-- Header -->
  <header>
    <div class="header-left">
      <div class="header-logo">🏨 SECURE<span>STAY</span></div>
      <div class="status-badge"><div class="status-dot"></div> SYSTEM ACTIVE</div>
    </div>
    <div class="header-right">
      <div class="header-time" id="live-clock">--:--:--</div>
      <button class="btn-logout" onclick="logout()">⏻ LOGOUT</button>
    </div>
  </header>

  <div class="layout">
    <!-- Sidebar -->
    <aside>
      <div class="nav-section">
        <div class="nav-label">Navigation</div>
        <div class="nav-item active" id="nav-live" onclick="showSection('live')"><span class="ni">📷</span> Live Feed <span class="alert-count" id="stat-intruders">0</span></div>
        <div class="nav-item" id="nav-employees" onclick="showSection('employees')"><span class="ni">👥</span> Personnel</div>
        <div class="nav-item" id="nav-attendance" onclick="showSection('attendance')"><span class="ni">📋</span> Attendance Logs</div>
        <div class="nav-item" id="nav-intruders" onclick="showSection('intruders')"><span class="ni">🚨</span> Security Alerts</div>
      </div>
      
      <!-- System Health Quick View -->
      <div class="nav-section" style="margin-top:auto; padding-top:24px; border-top:1px solid var(--border);">
        <div class="nav-label">System Health</div>
        <div style="font-size:12px; color:var(--text-muted); padding: 0 12px;">
            <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                <span>CPU: <strong id="health-cpu" style="color:var(--text)">--%</strong></span>
                <span>RAM: <strong id="health-mem" style="color:var(--text)">--%</strong></span>
            </div>
            <div style="display:flex; justify-content:space-between;">
                <span>DB: <strong id="health-db" style="color:var(--success)">--</strong></span>
                <span>CAM: <strong id="health-cam" style="color:var(--success)">--</strong></span>
            </div>
        </div>
      </div>
    </aside>

    <main>
      <!-- LIVE FEED PAGE -->
      <div class="page-section active" id="section-live">
        <div class="page-title">LIVE SURVEILLANCE</div>
        <div class="page-sub">// REAL-TIME THREAT DETECTION</div>

        <div class="grid-2col-uneven">
            <!-- Camera View -->
            <div class="section" style="padding:0; border:none; background:transparent; box-shadow:none;">
                <div class="cam-feed">
                    <div class="cam-label">CAM-01 / MAIN ENTRANCE</div>
                    <div class="cam-rec"><div class="cam-rec-dot"></div> LIVE INFERENCE</div>
                    <div class="feed-body">
                        <img id="videoFeed" src="" alt="Camera feed offline" />
                    </div>
                </div>
                
                <div class="stats-row" style="margin-top: 24px; grid-template-columns: 1fr 1fr;">
                    <div class="stat-card blue">
                        <div class="stat-label">Total Personnel</div>
                        <div class="stat-val" id="stat-employees">0</div>
                        <div class="stat-sub">Registered in DB</div>
                    </div>
                    <div class="stat-card green">
                        <div class="stat-label">Present Today</div>
                        <div class="stat-val" id="stat-present">0</div>
                        <div class="stat-sub">Verified attendance</div>
                    </div>
                </div>
            </div>

            <!-- Live Alerts Panel -->
            <div class="section" style="display:flex; flex-direction:column;">
                <div class="section-header">
                  <div class="section-title">ACTIVE <span>THREATS</span></div>
                </div>
                <div class="alerts-list" id="live-alerts-list" style="flex:1; overflow-y:auto;">
                    <p class="text-muted text-center" style="padding:20px;">Initializing threat scanner...</p>
                </div>
            </div>
        </div>
      </div>

      <!-- PERSONNEL DATABASE PAGE -->
      <div class="page-section" id="section-employees">
        <div class="page-title">PERSONNEL DATABASE</div>
        <div class="page-sub">// TRUSTED STAFF & IDENTITY MANAGEMENT</div>

        <div class="section">
            <div class="section-header">
                <div class="section-title">Enrolled <span>Identities</span></div>
            </div>
            <div class="persons-controls">
                <input type="text" class="search-box" placeholder="Search by ID, name or role..." />
            </div>
            <!-- Populated via script.js -->
            <div class="employee-list" id="employee-grid"></div>
        </div>
        
        <!-- Add New Person Form Form -->
        <div class="section">
            <div class="section-header">
                <div class="section-title">New <span>Enrollment</span></div>
            </div>
            <form id="add-employee-form" onsubmit="addEmployee(event)" style="max-width: 600px;">
                <div class="form-row">
                    <div class="form-group-sm">
                        <label>Personnel ID</label>
                        <input type="text" id="emp-id" required>
                    </div>
                    <div class="form-group-sm">
                        <label>Full Name</label>
                        <input type="text" id="emp-name" required>
                    </div>
                </div>
                <div class="form-group-sm" style="margin-bottom: 24px;">
                    <label>Department / Role</label>
                    <input type="text" id="emp-dept" required>
                </div>
                
                <div class="form-group-sm" style="margin-bottom: 24px;">
                    <label>Reference Images (Multiple allowed)</label>
                    <input type="file" id="emp-images" accept="image/*" multiple required>
                    <p class="text-muted" style="font-size:12px; margin-top:8px;">Upload clear, well-lit photos of the frontal face.</p>
                </div>
                
                <button type="submit" class="btn-primary">Enroll Personnel</button>
            </form>
        </div>
      </div>

      <!-- ATTENDANCE LOGS PAGE -->
      <div class="page-section" id="section-attendance">
        <div class="page-title">ATTENDANCE LEDGER</div>
        <div class="page-sub">// AUTOMATED TIME TRACKING VIA FACE RECOGNITION</div>

        <div class="section">
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Personnel</th>
                            <th>Check In</th>
                            <th>Check Out</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="attendance-tbody">
                        <!-- Polulated via script.js -->
                    </tbody>
                </table>
            </div>
        </div>
      </div>

      <!-- INTRUDER LOGS PAGE -->
      <div class="page-section" id="section-intruders">
        <div class="page-title">SECURITY INCIDENTS</div>
        <div class="page-sub">// HISTORICAL THREAT DETECTION LOGS</div>

        <div class="section">
            <div class="intruder-grid" id="intruder-grid">
                <!-- Populated via script.js -->
            </div>
        </div>
      </div>

    </main>
  </div>
</div>

<!-- Add Modal Image Lightbox -->
<div id="imageModal" class="modal">
  <span class="close-modal" onclick="closeModal()">&times;</span>
  <img class="modal-content" id="modalImage">
</div>

<script src="script.js"></script>
</body>
</html>
